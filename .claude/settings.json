{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(apt-get install -y *)",
      "Bash(gh *)",
      "Bash(bash install-skills.sh)",
      "Bash(deno *)"
    ]
  }
}
